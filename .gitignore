# Terraform local working directories and lockfiles
.terraform/
*.terraform
*.terraform.lock.hcl

# Terraform state - MUST be stored in GCS backend, never in git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output
*.tfplan
crash.log
crash.*.log

# Local backend config (may contain bucket names / impersonation SA)
backend.hcl

# Local override files (may contain secrets)
*.tfvars.local
*_override.tf
*_override.tf.json
override.tf
override.tf.json

# Secret values (auto-loaded by Terraform) - never commit real secret values
secrets.auto.tfvars
secrets.tfvars

# OS / editor cruft
.DS_Store
.idea/
.vscode/
