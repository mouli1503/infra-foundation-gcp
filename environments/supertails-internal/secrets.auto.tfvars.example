# Secret Manager values for the sup-internal-apps project.
#
# 1. Copy this file:   cp secrets.auto.tfvars.example secrets.auto.tfvars
# 2. Fill in real values in secrets.auto.tfvars
# 3. secrets.auto.tfvars is auto-loaded by Terraform and is GITIGNORED.
#    NEVER commit real secret values.

# ── pricing-engine (PROD, runs in sup-internal-apps) ─────────────────────────
# The app reads these UNSUFFIXED names from its own project via
# env_loader.bootstrap(). No suffix, no --set-secrets needed.
#
#   PE_DB_URL              -> pe-db-url               (prod DB; use DIRECT endpoint, not -pooler)
#   SESSION_SECRET         -> pe-session-secret
#   PORTAL_ADMIN_PASSWORD  -> pe-portal-admin-password
#   ANALYTICS_DB_HOST      -> pe-analytics-db-host    (same read-only analytics MySQL as staging)
#   ANALYTICS_DB_USER      -> pe-analytics-db-user    (copy staging value verbatim)
#   ANALYTICS_DB_PASS      -> pe-analytics-db-pass    (copy staging value verbatim)
#   ANALYTICS_DB_PORT      -> pe-analytics-db-port    (copy staging value verbatim)
#   CRON_SECRET            -> pe-cron-secret          (must match X-Cron-Secret on the pe-cron-* jobs)

secrets = {
  "pe-db-url"               = "REPLACE_ME"
  "pe-session-secret"       = "REPLACE_ME"
  "pe-portal-admin-password" = "REPLACE_ME"
  "pe-analytics-db-host"    = "REPLACE_ME"
  "pe-analytics-db-user"    = "REPLACE_ME"
  "pe-analytics-db-pass"    = "REPLACE_ME"
  "pe-analytics-db-port"    = "REPLACE_ME"
  "pe-cron-secret"          = "REPLACE_ME"
}

# Service account(s) granted secretAccessor on ALL secrets above
# (e.g. the pricing-engine prod Cloud Run runtime service account).
secret_accessors = [
  # "serviceAccount:REPLACE_ME@sup-internal-apps.iam.gserviceaccount.com",
]

# Optional: per-secret accessor overrides (overrides secret_accessors for that secret).
# secret_access_overrides = {}
